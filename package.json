{
  "name": "postforge",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "cd apps/web && pnpm run dev",
    "build": "turbo run build",
    "build:web": "cd apps/web && pnpm run build",
    "start": "cd apps/web && pnpm run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf apps/*/.next apps/*/node_modules node_modules packages/*/node_modules shared/node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.5.0"
  },
  "packageManager": "pnpm@10.6.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "unrs-resolver"]
  },
  "engines": {
    "node": ">=18"
  }
}
